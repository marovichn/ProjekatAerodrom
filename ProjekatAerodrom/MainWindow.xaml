<Window x:Class="ProjekatAerodrom.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ProjekatAerodrom"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <TabControl Margin="0" Background="#F9F9F9">

            <TabItem Header="Pregled Podataka" FontSize="14" Padding="10,5">
                <Grid Background="White">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="Dobrodošli na prvi tab!" 
                                   FontSize="22" 
                                   FontWeight="Bold" 
                                   Foreground="#333333"
                                   Margin="0,0,0,20" 
                                   HorizontalAlignment="Center"/>

                        <TextBlock Text="Ovdje možeš postaviti DataGrid ili ListBox za prikaz podataka." 
                                   FontSize="14" 
                                   Foreground="#666666"
                                   Margin="0,0,0,20" 
                                   HorizontalAlignment="Center"/>

                        <Button Content="Pokreni Akciju" 
                                Width="150" 
                                Height="35" 
                                Background="#007ACC" 
                                Foreground="White" 
                                FontWeight="Bold"
                                Click="BtnAkcija_Click"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem Header="Unos i Izmjena" FontSize="14" Padding="10,5">
                <Grid Background="White">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="Ovo je drugi tab aplikacije" 
                                   FontSize="20" 
                                   FontWeight="Bold" 
                                   Foreground="#333333"
                                   Margin="0,0,0,10"
                                   HorizontalAlignment="Center"/>

                        <TextBlock Text="Ovaj dio možeš iskoristiti za formu (TextBox, ComboBox) za unos novih stavki." 
                                   FontSize="14" 
                                   Foreground="#666666"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </TabItem>

        </TabControl>
    </Grid>
</Window>
